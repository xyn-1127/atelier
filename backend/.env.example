APP_NAME=Atelier
APP_ENV=dev
APP_DEBUG=true
APP_DATABASE_URL=sqlite:///./atelier.db
APP_LOG_LEVEL=INFO

# Bring your own LLM key. Default points at DeepSeek (OpenAI-compatible).
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner

# MAX_HISTORY_MESSAGES=20          # 聊天历史最大消息条数
# MAX_FILE_READ_SIZE=51200         # Agent 读取文件最大字节数（默认 50KB）
# MAX_SCAN_FILE_SIZE=104857600     # 扫描时跳过超过此大小的文件（默认 100MB）

# CHUNK_SIZE=500                   # 切块大小（字符数）
# CHUNK_OVERLAP=50                 # 相邻切块重叠字符数
# CHROMA_PERSIST_DIR=./chroma_data # ChromaDB 持久化目录

# COMPACT_TRIGGER=10               # 每累积 N 条未压缩消息触发 compact
# COMPACT_KEEP_RECENT=3            # compact 时保留最近 N 条完整消息
